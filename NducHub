function Load()
	if readfile and writefile and isfile and isfolder then
		if not isfolder("Nano X Hub") then
			makefolder("Nano X Hub")
		end
		if not isfolder("Nano X Hub") then
			makefolder("Nano X Hub")
		end
		if not isfile("Nano X Hub/" .. game.Players.LocalPlayer.Name .. "-BF.json") then
			writefile("Nano X Hub/" .. game.Players.LocalPlayer.Name .. "-BF.json", game:GetService("HttpService"):JSONEncode(_G.Config))
		else
			local Decode = game:GetService("HttpService"):JSONDecode(readfile("Nano X Hub/" .. game.Players.LocalPlayer.Name .. "-BF.json"))
			for i, v in pairs(Decode) do
				_G.Config[i] = v
			end
		end
	end
end
function SaveSetting()
	if readfile and writefile and isfile and isfolder then
		if not isfile("Nano X Hub/" .. game.Players.LocalPlayer.Name .. "-BF.json") then
			Load()
		else
			local Decode = game:GetService("HttpService"):JSONDecode(readfile("Nano X Hub/" .. game.Players.LocalPlayer.Name .. "-BF.json"))
			local Array = {}
			for i, v in pairs(_G.Config) do
				Array[i] = v
			end
			writefile("Nano X Hub/" .. game.Players.LocalPlayer.Name .. "-BF.json", game:GetService("HttpService"):JSONEncode(Array))
		end
	end
end
