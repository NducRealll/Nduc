-- Hàm kiểm tra giữ lại part quan trọng (chỉ giữ player và quái)
local function shouldKeepPart(part)
    local parent = part.Parent
    local maxDepth = 10
    local depth = 0
    
    while parent and depth < maxDepth do
        -- Giữ character, NPC, quái, boss
        if parent:FindFirstChild("Humanoid") then
            return true
        end
        
        local nameLower = parent.Name:lower()
        if nameLower:match("npc") or nameLower:match("boss") or 
           nameLower:match("monster") or nameLower:match("zombie") or 
           nameLower:match("enemy") or nameLower:match("player") or
           nameLower:match("character") or nameLower:match("pet") or
           nameLower:match("humanoid") then
            return true
        end
        
        parent = parent.Parent
        depth = depth + 1
    end
    return false
end

-- Xóa 100% map (chỉ giữ quái, boss, player)
